#!/bin/bash
# sos_workspace_sentinel.sh - Versión 1.5
# Fix: read desde /dev/tty, soporte .sh/.c, comentarios C (// y /* */)
# NOTA: NO agregar headers MFN a este archivo (se movería a sí mismo)

WORKSPACE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INBOX="$WORKSPACE/inbox"
QUARANTINE="$INBOX/quarantine"
LOG_FILE="$WORKSPACE/data/logs/sentinel_audit.log"
MFN_MAP="$WORKSPACE/data/mfn_location_map.json"

mkdir -p "$INBOX" "$QUARANTINE" "$(dirname "$LOG_FILE")"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# ═══════════════════════════════════════════════════════════════
# FIX 1: Detectar MFN_LOCATION en .py, .yaml, .sh, .c
# ═══════════════════════════════════════════════════════════════
extract_mfn_location() {
    local file="$1"
    local location=""
    
    # Intento 1: Formato Python (sin #)
    location=$(grep -m1 "^MFN_LOCATION:" "$file" 2>/dev/null | cut -d' ' -f2 | tr -d '\r\n')
    
    # Intento 2: Formato YAML/Bash/Python con comentario (# MFN_LOCATION: ...)
    if [ -z "$location" ]; then
        location=$(grep -m1 "^#[[:space:]]*MFN_LOCATION:" "$file" 2>/dev/null | sed 's/^#[[:space:]]*MFN_LOCATION:[[:space:]]*//' | tr -d '\r\n')
    fi
    
    # Intento 3: Formato C con // (// MFN_LOCATION: ...)
    if [ -z "$location" ]; then
        location=$(grep -m1 "^//[[:space:]]*MFN_LOCATION:" "$file" 2>/dev/null | sed 's|^//[[:space:]]*MFN_LOCATION:[[:space:]]*||' | tr -d '\r\n')
    fi
    
    # Intento 4: Formato C con /* */ (/* MFN_LOCATION: ... */)
    if [ -z "$location" ]; then
        location=$(grep -m1 "/\*[[:space:]]*MFN_LOCATION:" "$file" 2>/dev/null | sed 's|/\*[[:space:]]*MFN_LOCATION:[[:space:]]*||' | sed 's|[[:space:]]*\*/||' | tr -d '\r\n')
    fi
    
    # Intento 5: Formato .md (con #)
    if [ -z "$location" ]; then
        location=$(grep -m1 "^#[[:space:]]*MFN_LOCATION:" "$file" 2>/dev/null | sed 's/^#[[:space:]]*MFN_LOCATION:[[:space:]]*//' | tr -d '\r\n')
    fi

    # Limpiar trailing slash y normalizar doble slash
    location=$(echo "$location" | sed 's/\/$//' | sed 's/\/\+/\//g')
    
    echo "$location"
}

# ═══════════════════════════════════════════════════════════════
# FIX 2: Preguntar desde /dev/tty (resuelve problema del pipe)
# ═══════════════════════════════════════════════════════════════
ensure_directory() {
    local dest_dir="$1"
    local filename="$2"
    
    if [ -d "$dest_dir" ]; then
        return 0
    fi
    
    # Modo automático
    if [ "$AUTO_MODE" = "true" ]; then
        mkdir -p "$dest_dir"
        log "📁 CREADA AUTOMÁTICAMENTE: $dest_dir"
        return 0
    fi
    
    # FIX CRÍTICO: Leer desde /dev/tty para interactuar con el terminal
    # aunque el stdin esté ocupado por el pipe de inotifywait
    echo "" > /dev/tty
    echo "⚠️  La carpeta destino NO existe: $dest_dir" > /dev/tty
    echo "   Archivo a mover: $filename" > /dev/tty
    echo "" > /dev/tty
    
    local respuesta=""
    read -t 10 -p "¿Crear la carpeta y mover el archivo? (s/n) [10s timeout]: " respuesta < /dev/tty 2>/dev/tty
    
    case "$respuesta" in
        s|S|si|SI|sí|SÍ|y|Y)
            mkdir -p "$dest_dir"
            log "📁 CREADA POR CONFIRMACIÓN: $dest_dir"
            return 0
            ;;
        *)
            log "❌ CANCELADO/TIMEOUT: Carpeta no creada. Archivo en cuarentena."
            return 1
            ;;
    esac
}

route_file() {
    local file="$1"
    local mfn_location="$2"

    if [[ "$file" == *"/quarantine/"* ]]; then
        return 0
    fi

    if [ ! -f "$file" ]; then
        return 0
    fi

    # Protección: NO mover el propio centinela
    if [[ "$(basename "$file")" == "sos_workspace_sentinel.sh" ]]; then
        log "🚫 PROTECCIÓN: No se puede mover el propio centinela"
        mv "$file" "$QUARANTINE/" 2>/dev/null
        return 1
    fi

    if [ -z "$mfn_location" ]; then
        log "⚠️  SIN MFN_LOCATION: $(basename "$file") → cuarentena"
        mv "$file" "$QUARANTINE/" 2>/dev/null
        return 1
    fi

    local dest_dir="$WORKSPACE/$mfn_location"
    local filename=$(basename "$file")
    
    if ! ensure_directory "$dest_dir" "$filename"; then
        mv "$file" "$QUARANTINE/" 2>/dev/null
        return 1
    fi

    # ✅ CORRECCIÓN: Primero definir dest_path
    local dest_path="$dest_dir/$filename"

    # ✅ CORRECCIÓN: Si el archivo destino existe, hacer backup PRIMERO
    if [ -f "$dest_path" ]; then
        local backup_dir="$dest_dir/.backups"
        mkdir -p "$backup_dir"
        
        # Renombrar el archivo EXISTENTE con timestamp y copiar a backups
        local timestamp=$(date +%s)
        local name="${filename%.*}"
        local ext="${filename##*.}"
        local backup_name="${name}_${timestamp}.${ext}"
        
        cp "$dest_path" "$backup_dir/$backup_name"
        log "💾 BACKUP: $filename → .backups/$backup_name"
    fi

    # ✅ Ahora mover el NUEVO archivo al destino (sobrescribiendo)
    mv "$file" "$dest_path" 2>/dev/null
    log "✅ ENRUTADO: $filename → $mfn_location/"

    echo "{\"file\": \"$dest_path\", \"location\": \"$mfn_location\", \"timestamp\": \"$(date -Iseconds)\"}" >> "$MFN_MAP"

    if [ -f "$WORKSPACE/tools/generate_path_map.py" ]; then
        python3 "$WORKSPACE/tools/generate_path_map.py" 2>/dev/null &
    fi

    return 0
}

process_file() {
    local file="$1"
    local event="$2"

    if [[ "$event" != *"CREATE"* ]]; then
        return 0
    fi

    if [ -d "$file" ]; then
        return 0
    fi

    if [[ "$file" == *"/quarantine/"* ]]; then
        return 0
    fi

    # FIX: Agregado .sh y .c al filtro
    if [[ ! "$file" =~ \.(py|yaml|yml|sh|c|md)$ ]]; then
        return 0
    fi

    log "📄 DETECTADO: CREATE → $(basename "$file")"
    sleep 0.5

    if [ ! -f "$file" ]; then
        return 0
    fi

    local mfn_location=$(extract_mfn_location "$file")
    route_file "$file" "$mfn_location"
}

# ═══════════════════════════════════════════════════════════════
# PARSEO DE ARGUMENTOS
# ═══════════════════════════════════════════════════════════════
AUTO_MODE="false"
for arg in "$@"; do
    case $arg in
        --auto)
            AUTO_MODE="true"
            ;;
    esac
done

log "👁️  WORKSPACE SENTINEL v1.5 INICIADO"
log "📂 Vigilando: $INBOX"
log "🔔 Solo CREATE | Modo: $([ "$AUTO_MODE" = "true" ] && echo 'AUTOMÁTICO' || echo 'INTERACTIVO')"
log "📋 Soporta: .py, .yaml, .yml, .sh, .md, .c (con #, // o /* */)"

if ! command -v inotifywait &> /dev/null; then
    log "❌ inotifywait no instalado. sudo apt install inotify-tools"
    exit 1
fi

inotifywait -m -e create --format '%w%f %e' "$INBOX" 2>/dev/null | \
while read file event; do
    process_file "$file" "$event"
done
